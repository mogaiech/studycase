  "item": [
    {
      "name": "Availability",
      "item": [
        {
          "name": "Check availability by date only",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/availability?date=2026-03-01",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "availability"
              ],
              "query": [
                {
                  "key": "date",
                  "value": "2026-03-01",
                  "description": "Selected date (yyyy-MM-dd)."
                }
              ]
            },
            "description": "Returns all professionals with their available time windows for the given day."
          },
          "response": []
        },
        {
          "name": "Check availability by date + time + duration (2h)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/availability?date=2026-03-02&startTime=10:00&durationHours=2",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "availability"
              ],
              "query": [
                {
                  "key": "date",
                  "value": "2026-03-02",
                  "description": "Selected date (yyyy-MM-dd)."
                },
                {
                  "key": "startTime",
                  "value": "10:00",
                  "description": "Appointment start time (HH:mm)."
                },
                {
                  "key": "durationHours",
                  "value": "2",
                  "description": "Duration in hours (2 or 4)."
                }
              ]
            },
            "description": "Returns professionals available for the exact 2-hour window starting at 10:00."
          },
          "response": []
        },
        {
          "name": "Check availability by date + time + duration (4h)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/availability?date=2026-03-02&startTime=14:00&durationHours=4",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "availability"
              ],
              "query": [
                {
                  "key": "date",
                  "value": "2026-03-02",
                  "description": "Selected date (yyyy-MM-dd). Fridays are not available."
                },
                {
                  "key": "startTime",
                  "value": "14:00",
                  "description": "Appointment start time (HH:mm)."
                },
                {
                  "key": "durationHours",
                  "value": "4",
                  "description": "Duration in hours (2 or 4)."
                }
              ]
            },
            "description": "Returns professionals available for the exact 4-hour window starting at 14:00."
          },
          "response": []
        },
        {
          "name": "Check availability on a Friday",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/availability?date=2026-03-06",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "availability"
              ],
              "query": [
                {
                  "key": "date",
                  "value": "2026-03-06",
                  "description": "A Friday - expected to return an error."
                }
              ]
            },
            "description": "Fridays are not available. Expects a 400 error."
          },
          "response": []
        },
        {
          "name": "Check availability on a past date",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/availability?date=2026-03-06",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "availability"
              ],
              "query": [
                {
                  "key": "date",
                  "value": "2026-03-06",
                  "description": "A Friday - expected to return an error."
                }
              ]
            },
            "description": "Fridays are not available. Expects a 400 error."
          },
          "response": []
        }
      ],
      "description": "Check professional availability"
    },
    {
      "name": "Bookings",
